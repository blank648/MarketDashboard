@inject NavigationManager Nav

<nav class="nav-menu">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        <span class="nav-icon">🏠</span> Home
    </NavLink>

    <AuthorizeView>
        <Authorized>
            <NavLink class="nav-item" href="dashboard" Match="NavLinkMatch.Prefix">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="nav-item" href="watchlist" Match="NavLinkMatch.Prefix">
                <span class="nav-icon">⭐</span> Watchlist
            </NavLink>
            <NavLink class="nav-item" href="alerts" Match="NavLinkMatch.Prefix">
                <span class="nav-icon">🔔</span> Alerts
            </NavLink>
            <NavLink class="nav-item" href="historical" Match="NavLinkMatch.Prefix">
                <span class="nav-icon">📉</span> Historical
            </NavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <hr class="nav-divider" />
            <NavLink class="nav-item nav-item-admin" href="admin"
                     Match="NavLinkMatch.Prefix">
                <span class="nav-icon">⚙️</span> Admin
            </NavLink>
        </Authorized>
    </AuthorizeView>
</nav>
