@inherits LayoutComponentBase

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">📈</span>
            <span class="sidebar-title">MarketDash</span>
        </div>
        <NavMenu />
    </aside>
    <div class="main-content">
        <header class="top-bar">
            <div class="top-bar-left">
                <span class="page-context">Financial Market Dashboard</span>
            </div>
            <div class="top-bar-right">
                <AuthorizeView>
                    <Authorized>
                        <span class="user-email">@context.User.Identity?.Name</span>
                        <form action="Account/Logout" method="post" class="d-inline">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button type="submit" class="btn btn-sm btn-outline-light ms-3">
                                Log out
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="Account/Login" class="btn btn-sm btn-outline-light">
                            Log in
                        </a>
                        <a href="Account/Register"
                           class="btn btn-sm btn-light ms-2">Register</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>
        <main class="page-body">
            @Body
        </main>
    </div>
</div>
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
