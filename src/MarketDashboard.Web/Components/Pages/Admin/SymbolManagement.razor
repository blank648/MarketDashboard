@page "/admin/symbols"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using MarketDashboard.Infrastructure.Services
@using MarketDashboard.Core.Entities
@inject AdminService AdminService
@inject ILogger<SymbolManagement> Logger

<PageTitle>Symbol Management — MarketDash</PageTitle>

<div class="page-header">
    <h2>Symbol Management</h2>
    <p>Add or deactivate tracked market symbols</p>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-error" : "alert-success")">
        @_message
    </div>
}

@using MarketDashboard.Web.Models

<div class="card" style="margin-bottom:24px;">
    <h5>Add New Symbol</h5>
    <EditForm Model="_addModel" OnValidSubmit="AddSymbolAsync" FormName="add-symbol">
        <DataAnnotationsValidator />
        
        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end; margin-top:16px;">
            <div class="form-group">
                <label class="form-label">Ticker</label>
                <InputText class="form-input"
                           @bind-Value="_addModel.Ticker"
                           @bind-Value:after="() => _addModel.Ticker = _addModel.Ticker?.ToUpper() ?? string.Empty"
                           placeholder="e.g. MSFT"
                           style="width:120px;" />
                <ValidationMessage For="() => _addModel.Ticker" class="validation-message" />
            </div>
            <div class="form-group">
                <label class="form-label">Company Name</label>
                <InputText class="form-input"
                           @bind-Value="_addModel.CompanyName"
                           placeholder="e.g. Microsoft Corp"
                           style="width:220px;" />
                <ValidationMessage For="() => _addModel.CompanyName" class="validation-message" />
            </div>
            <button type="submit" class="btn btn-primary"
                    disabled="@_isAdding">
                @(_isAdding ? "Adding..." : "+ Add Symbol")
            </button>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(_addError))
    {
        <p style="color:var(--accent-red);font-size:13px;margin-top:8px;">
            @_addError
        </p>
    }
</div>

<div class="card">
    @if (_isLoading)
    {
        <div class="loading-row">
            <div class="spinner-sm"></div>
            <span>Loading symbols...</span>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ticker</th>
                    <th>Company Name</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _symbols)
                {
                    <tr>
                        <td style="font-family:var(--font-mono); font-weight:600;">
                            @s.Ticker
                        </td>
                        <td>@s.CompanyName</td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge badge-active">
                                    ● Active
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">
                                    ○ Inactive
                                </span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm @(s.IsActive ? "btn-warning" : "btn-primary")"
                                    @onclick="() => ToggleSymbolAsync(s.Id)"
                                    disabled="@(_processingId == s.Id)">
                                @(s.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Symbol> _symbols = [];
    private AddSymbolModel _addModel = new();
    private string _message = string.Empty;
    private string _addError = string.Empty;
    private bool _isError;
    private bool _isLoading = true;
    private bool _isAdding;
    private int _processingId;

    protected override async Task OnInitializedAsync()
    {
        await LoadSymbolsAsync();
    }

    private async Task LoadSymbolsAsync()
    {
        _isLoading = true;
        try
        {
            var result = await AdminService
                .GetAllSymbolsAsync(CancellationToken.None);
            _symbols = result.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load symbols");
        }
        finally { _isLoading = false; }
    }

    private async Task AddSymbolAsync()
    {
        _addError = string.Empty;
        _isAdding = true;
        try
        {
            await AdminService.AddSymbolAsync(
                _addModel.Ticker, _addModel.CompanyName, CancellationToken.None);
            _message = $"Symbol {_addModel.Ticker} added successfully.";
            _isError = false;
            _addModel = new();
            await LoadSymbolsAsync();
        }
        catch (Exception ex)
        {
            _addError = ex.Message;
        }
        finally { _isAdding = false; }
    }

    private async Task ToggleSymbolAsync(int symbolId)
    {
        _processingId = symbolId;
        try
        {
            var status = await AdminService
                .ToggleSymbolActiveAsync(symbolId, CancellationToken.None);
            _message = $"Symbol {status}.";
            _isError = false;
            await LoadSymbolsAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _isError = true;
        }
        finally { _processingId = 0; }
    }
}
